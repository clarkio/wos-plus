                width="75%"
                height="75%"
                viewBox="0 0 24 24"
                preserveAspectRatio="xMidYMid meet"
                fill="currentcolor"
              >
                <path
                  d="M12 6a7 7 0 1 0 0 14 7 7 0 0 0 0-14zm1 8h-2V8h2v6z"
                  opacity=".3"></path>
                <path d="M9 1h6v2H9z"></path>
